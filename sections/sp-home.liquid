{%- comment -%}
  Squeeze Project — Home
  One custom section that paints the whole homepage in a warm, Jellycat-style
  layout: hero → camp collections → mission band → shipping options →
  coming-soon strip → story teaser. All copy is editable in the theme editor.
{%- endcomment -%}

<style>
  /* ─── Section scope ─── */
  .sp-home {
    --sp-cream:   #faf8f3;
    --sp-cream-2: #f0ebe0;
    --sp-sage:    #e8efe5;
    --sp-yellow:  #fff8e0;
    --sp-green:   #1a4f30;
    --sp-green-2: #2e7d4f;
    --sp-orange:  #e8793a;
    --sp-gold:    #f5c842;
    --sp-ink:     #2a2a2a;
    --sp-muted:   #6a6a6a;
    --sp-border:  #d4ccba;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    color: var(--sp-ink);
    line-height: 1.6;
  }
  .sp-home * { box-sizing: border-box; }
  .sp-home a { color: inherit; text-decoration: none; }

  .sp-wrap { max-width: 1180px; margin: 0 auto; padding: 0 20px; }
  .sp-kicker {
    display: inline-block;
    font-size: 11px; font-weight: 800; letter-spacing: 2px;
    text-transform: uppercase; color: var(--sp-green-2);
    margin-bottom: 14px;
  }
  .sp-h1 {
    font-family: Fraunces, 'Times New Roman', serif;
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.05;
    font-size: clamp(40px, 7vw, 76px); color: var(--sp-green);
    margin: 0 0 22px;
  }
  .sp-h1 em { font-style: italic; color: var(--sp-orange); }
  .sp-h2 {
    font-family: Fraunces, 'Times New Roman', serif;
    font-weight: 700; letter-spacing: -0.015em; line-height: 1.1;
    font-size: clamp(28px, 4.5vw, 48px); color: var(--sp-green);
    margin: 0 0 16px;
  }
  .sp-lede {
    font-size: clamp(16px, 1.6vw, 19px); color: var(--sp-muted);
    max-width: 580px; margin: 0 auto 30px; line-height: 1.6;
  }
  .sp-btn {
    display: inline-block;
    padding: 16px 32px; border-radius: 999px;
    font-weight: 800; font-size: 15px; letter-spacing: 0.02em;
    transition: transform .15s ease, box-shadow .15s ease;
    cursor: pointer;
  }
  .sp-btn-primary {
    background: var(--sp-green); color: #fff;
    box-shadow: 0 4px 16px rgba(26, 79, 48, .25);
  }
  .sp-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26, 79, 48, .35); }
  .sp-btn-ghost {
    color: var(--sp-green); padding: 16px 26px;
    border: 2px solid transparent;
  }
  .sp-btn-ghost:hover { border-color: var(--sp-green); }
  .sp-btn-yellow {
    background: var(--sp-gold); color: var(--sp-green);
    box-shadow: 0 4px 16px rgba(245, 200, 66, .35);
  }
  .sp-btn-yellow:hover { transform: translateY(-2px); }

  /* ─── HERO ─── */
  .sp-hero {
    background: linear-gradient(165deg, #faf8f3 0%, #f0ebe0 60%, #e8efe5 100%);
    padding: clamp(56px, 9vw, 110px) 0 clamp(64px, 10vw, 120px);
    text-align: center;
    position: relative; overflow: hidden;
  }
  .sp-hero::before, .sp-hero::after {
    content: ''; position: absolute; border-radius: 50%;
    pointer-events: none; opacity: .35;
  }
  .sp-hero::before {
    width: 320px; height: 320px; left: -80px; top: 40px;
    background: radial-gradient(circle, #e8793a55 0%, transparent 70%);
  }
  .sp-hero::after {
    width: 360px; height: 360px; right: -100px; bottom: -40px;
    background: radial-gradient(circle, #1a4f3055 0%, transparent 70%);
  }
  .sp-hero-inner { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; }
  .sp-hero-pill {
    display: inline-flex; align-items: center; gap: 8px;
    background: #fff; border: 1.5px solid var(--sp-border);
    color: var(--sp-green); font-weight: 700; font-size: 12px;
    padding: 8px 16px; border-radius: 999px; margin-bottom: 28px;
    letter-spacing: 0.04em; text-transform: uppercase;
  }
  .sp-hero-pill .sp-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--sp-gold); }
  .sp-hero .sp-h1 { text-align: center; }
  .sp-hero-buttons { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 8px; }
  .sp-trust {
    margin-top: 36px; font-size: 12px; color: var(--sp-muted);
    letter-spacing: 0.08em; text-transform: uppercase; font-weight: 600;
  }
  .sp-trust strong { color: var(--sp-green); font-weight: 800; }

  /* ─── CAMP COLLECTIONS ─── */
  .sp-camps { padding: clamp(64px, 8vw, 110px) 0; background: #fff; }
  .sp-camps .sp-h2, .sp-camps .sp-kicker { text-align: center; display: block; margin-left: auto; margin-right: auto; }
  .sp-camps-grid {
    display: grid; gap: 18px; margin-top: 44px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  @media (max-width: 720px) { .sp-camps-grid { grid-template-columns: 1fr; } }
  .sp-camp {
    position: relative; display: block; border-radius: 28px;
    padding: 36px 32px 32px; overflow: hidden;
    min-height: 360px;
    color: #fff;
    transition: transform .25s ease, box-shadow .25s ease;
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .sp-camp:hover { transform: translateY(-4px); box-shadow: 0 20px 50px rgba(0,0,0,.18); }
  .sp-camp-emoji {
    font-size: 96px; line-height: 1;
    align-self: center; margin: 12px 0 24px;
    filter: drop-shadow(0 8px 20px rgba(0,0,0,.18));
  }
  .sp-camp-name {
    font-family: Fraunces, 'Times New Roman', serif;
    font-size: 32px; font-weight: 700; letter-spacing: -0.01em;
    margin: 0 0 6px;
  }
  .sp-camp-sub { font-size: 14px; opacity: .85; }
  .sp-camp-cta {
    margin-top: 22px; display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,.18); border: 1px solid rgba(255,255,255,.3);
    color: #fff; padding: 10px 18px; border-radius: 999px;
    font-size: 13px; font-weight: 700; align-self: flex-start;
  }
  .sp-camp-cta:hover { background: rgba(255,255,255,.28); }
  .sp-camp-badge {
    position: absolute; top: 20px; right: 20px;
    background: rgba(255,255,255,.95); color: var(--sp-green);
    font-size: 10px; font-weight: 800; letter-spacing: 0.12em;
    text-transform: uppercase; padding: 6px 12px; border-radius: 999px;
  }
  .sp-camp.ihc      { background: linear-gradient(160deg, #4A6FA5 0%, #2c4773 100%); }
  .sp-camp.pontiac  { background: linear-gradient(160deg, #CC0000 0%, #8a0000 100%); }

  /* ─── MISSION BAND ─── */
  .sp-mission {
    background: linear-gradient(135deg, var(--sp-green) 0%, #0f3d1c 100%);
    color: #fff; padding: clamp(64px, 8vw, 110px) 0;
    position: relative; overflow: hidden;
  }
  .sp-mission::before {
    content: ''; position: absolute;
    width: 500px; height: 500px; right: -150px; top: -150px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245,200,66,.18) 0%, transparent 70%);
  }
  .sp-mission-inner { position: relative; z-index: 1; max-width: 820px; }
  .sp-mission .sp-kicker { color: var(--sp-gold); }
  .sp-mission .sp-h2 { color: #fff; }
  .sp-mission .sp-h2 em { color: var(--sp-gold); font-style: italic; }
  .sp-mission p {
    font-size: clamp(15px, 1.5vw, 18px); line-height: 1.7;
    opacity: .9; max-width: 640px; margin: 0 0 28px;
  }
  .sp-mission .sp-mission-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--sp-gold); font-weight: 700; font-size: 15px;
    border-bottom: 2px solid transparent;
    padding-bottom: 2px; transition: border-color .2s;
  }
  .sp-mission .sp-mission-link:hover { border-color: var(--sp-gold); }

  /* ─── SHIPPING / PICKUP ─── */
  .sp-ship { padding: clamp(64px, 8vw, 110px) 0; background: var(--sp-cream); }
  .sp-ship .sp-kicker, .sp-ship .sp-h2 { text-align: center; display: block; margin-left: auto; margin-right: auto; }
  .sp-ship .sp-lede { text-align: center; }
  .sp-ship-grid {
    display: grid; gap: 18px; margin-top: 40px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  @media (max-width: 760px) { .sp-ship-grid { grid-template-columns: 1fr; } }
  .sp-ship-card {
    background: #fff; border: 1.5px solid var(--sp-border);
    border-radius: 20px; padding: 30px 28px;
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .sp-ship-card:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(0,0,0,.08); }
  .sp-ship-icon {
    width: 56px; height: 56px; border-radius: 16px;
    background: var(--sp-cream-2); color: var(--sp-green);
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; margin-bottom: 18px;
  }
  .sp-ship-title {
    font-family: Fraunces, 'Times New Roman', serif;
    font-size: 22px; font-weight: 700; color: var(--sp-green);
    margin: 0 0 8px;
  }
  .sp-ship-price {
    display: inline-block;
    font-size: 12px; font-weight: 800; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--sp-orange);
    margin-bottom: 12px;
  }
  .sp-ship-body { font-size: 14px; color: var(--sp-muted); line-height: 1.7; margin: 0; }

  /* ─── COMING SOON MARQUEE ─── */
  .sp-soon {
    background: var(--sp-green); color: #fff;
    padding: 28px 0; overflow: hidden; position: relative;
  }
  .sp-soon-track {
    display: flex; gap: 60px; white-space: nowrap;
    animation: spMarquee 28s linear infinite;
    width: max-content;
  }
  .sp-soon-track span {
    font-family: Fraunces, 'Times New Roman', serif;
    font-size: clamp(24px, 3vw, 34px); font-weight: 600;
    letter-spacing: -0.01em; color: rgba(255,255,255,.7);
  }
  .sp-soon-track span em {
    font-style: normal; color: var(--sp-gold); font-weight: 700;
  }
  @keyframes spMarquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ─── STORY TEASER ─── */
  .sp-story {
    background: var(--sp-cream); padding: clamp(64px, 8vw, 110px) 0;
  }
  .sp-story-grid {
    display: grid; gap: 60px; align-items: center;
    grid-template-columns: 5fr 6fr;
  }
  @media (max-width: 860px) {
    .sp-story-grid { grid-template-columns: 1fr; gap: 36px; }
  }
  .sp-story-img {
    aspect-ratio: 4/5; border-radius: 28px;
    background:
      radial-gradient(circle at 30% 20%, rgba(255,255,255,.5) 0%, transparent 50%),
      linear-gradient(160deg, #2e7d4f 0%, #1a4f30 70%, #0f3d1c 100%);
    display: flex; align-items: center; justify-content: center;
    color: #fff; text-align: center; padding: 40px;
    box-shadow: 0 20px 60px rgba(26, 79, 48, .25);
    position: relative; overflow: hidden;
  }
  .sp-story-img::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 70% 80%, rgba(245,200,66,.25) 0%, transparent 50%);
  }
  .sp-story-img-emoji {
    font-size: 120px; line-height: 1; margin-bottom: 18px;
    filter: drop-shadow(0 8px 24px rgba(0,0,0,.25));
    position: relative; z-index: 1;
  }
  .sp-story-img-cap {
    position: relative; z-index: 1;
    font-family: Fraunces, 'Times New Roman', serif;
    font-style: italic; font-size: 20px; opacity: .95;
  }
  .sp-story-body h2 { text-align: left; }
  .sp-story-body p {
    font-size: 16px; color: var(--sp-muted); line-height: 1.75;
    margin: 0 0 22px; max-width: 520px;
  }
  .sp-story-cta {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--sp-green); font-weight: 700; font-size: 15px;
    border-bottom: 2px solid var(--sp-green); padding-bottom: 2px;
  }
  .sp-story-cta:hover { color: var(--sp-orange); border-color: var(--sp-orange); }
</style>

<div class="sp-home">

  {%- comment -%}── HERO ─{%- endcomment -%}
  <section class="sp-hero">
    <div class="sp-wrap sp-hero-inner">
      {%- if section.settings.hero_pill != blank -%}
        <span class="sp-hero-pill">
          <span class="sp-dot"></span>{{ section.settings.hero_pill }}
        </span>
      {%- endif -%}
      <h1 class="sp-h1">{{ section.settings.hero_heading | default: 'Squeeze toys, made for <em>camp</em>.' }}</h1>
      {%- if section.settings.hero_lede != blank -%}
        <p class="sp-lede">{{ section.settings.hero_lede }}</p>
      {%- endif -%}
      <div class="sp-hero-buttons">
        <a href="{{ section.settings.hero_cta_link | default: '/collections/all' }}" class="sp-btn sp-btn-primary">
          {{ section.settings.hero_cta_text | default: 'Shop the camps' }}
        </a>
        {%- if section.settings.hero_cta2_text != blank -%}
          <a href="{{ section.settings.hero_cta2_link | default: '#camps' }}" class="sp-btn sp-btn-ghost">
            {{ section.settings.hero_cta2_text }} →
          </a>
        {%- endif -%}
      </div>
      <div class="sp-trust">
        <strong>100% of profits</strong> help send kids to camp · 501(c)(3) approved
      </div>
    </div>
  </section>

  {%- comment -%}── CAMP COLLECTIONS ─{%- endcomment -%}
  <section class="sp-camps" id="camps">
    <div class="sp-wrap">
      <span class="sp-kicker">By Camp</span>
      <h2 class="sp-h2">Pick your camp.</h2>
      <div class="sp-camps-grid">
        <a class="sp-camp ihc" href="{{ section.settings.ihc_link | default: '/collections/camp-ihc' }}">
          <span class="sp-camp-badge">Pre-order · Ships July</span>
          <span class="sp-camp-emoji">🏕️</span>
          <div>
            <h3 class="sp-camp-name">Camp IHC</h3>
            <div class="sp-camp-sub">Original + Glitter · $10</div>
            <span class="sp-camp-cta">Shop IHC →</span>
          </div>
        </a>
        <a class="sp-camp pontiac" href="{{ section.settings.pontiac_link | default: '/collections/camp-pontiac' }}">
          <span class="sp-camp-badge">Pre-order · Ships July</span>
          <span class="sp-camp-emoji">🏕️</span>
          <div>
            <h3 class="sp-camp-name">Camp Pontiac</h3>
            <div class="sp-camp-sub">Original + Glitter · $10</div>
            <span class="sp-camp-cta">Shop Pontiac →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  {%- comment -%}── MISSION BAND ─{%- endcomment -%}
  <section class="sp-mission">
    <div class="sp-wrap sp-mission-inner">
      <span class="sp-kicker">Why we're here</span>
      <h2 class="sp-h2">More than a toy. A way to send more kids to <em>camp</em> every summer.</h2>
      <p>{{ section.settings.mission_body | default: 'Every toy is designed for a specific camp, manufactured once from a custom mold, and sold to fund camp scholarships through SCOPE — the national charity behind The Squeeze Project. Sell one toy, fund camp. Forever.' }}</p>
      <a class="sp-mission-link" href="{{ section.settings.mission_link | default: 'https://thesqueezeproject.com' }}">
        Read our story →
      </a>
    </div>
  </section>

  {%- comment -%}── SHIPPING ─{%- endcomment -%}
  <section class="sp-ship">
    <div class="sp-wrap">
      <span class="sp-kicker">How it ships</span>
      <h2 class="sp-h2">Three ways to get your toy.</h2>
      <p class="sp-lede">Pick what works for your camp.</p>
      <div class="sp-ship-grid">
        <div class="sp-ship-card">
          <div class="sp-ship-icon">🏕️</div>
          <div class="sp-ship-price">Free</div>
          <h3 class="sp-ship-title">Camp pickup</h3>
          <p class="sp-ship-body">Grab your toy at visiting day or parents weekend — no shipping cost, no waiting on a package.</p>
        </div>
        <div class="sp-ship-card">
          <div class="sp-ship-icon">📦</div>
          <div class="sp-ship-price">$5 flat</div>
          <h3 class="sp-ship-title">USPS to your door</h3>
          <p class="sp-ship-body">Standard mail anywhere in the US. Tracked, delivered within a week of fulfillment.</p>
        </div>
        <div class="sp-ship-card">
          <div class="sp-ship-icon">👥</div>
          <div class="sp-ship-price">Save more</div>
          <h3 class="sp-ship-title">Order together</h3>
          <p class="sp-ship-body">Bundle with bunkmates or other camp families — split shipping across the order to spend less.</p>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%}── COMING SOON MARQUEE ─{%- endcomment -%}
  <section class="sp-soon" aria-label="Coming soon camps">
    <div class="sp-soon-track">
      {%- assign soon_camps = 'Wah-Nee,Westmont,Tyler Hill,Towanda,Timber Lake' | split: ',' -%}
      {%- for i in (1..3) -%}
        {%- for camp in soon_camps -%}
          <span>{{ camp }} <em>· coming soon</em></span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </section>

  {%- comment -%}── STORY TEASER ─{%- endcomment -%}
  <section class="sp-story">
    <div class="sp-wrap">
      <div class="sp-story-grid">
        <div class="sp-story-img">
          <div>
            <div class="sp-story-img-emoji">🍋</div>
            <div class="sp-story-img-cap">"Camp is the gift."</div>
          </div>
        </div>
        <div class="sp-story-body">
          <span class="sp-kicker">The bigger picture</span>
          <h2 class="sp-h2">A kid-led mission, built to last.</h2>
          <p>The Squeeze Project started with a question: how do you keep sending kids to camp without ever asking for donations again? The answer became a custom squeeze toy for each camp — sold once, scholarship-funding forever.</p>
          <p>Every toy you buy here funds that mission. The fundraiser site has the full story, the ambassadors behind each camp, and live progress on the goal.</p>
          <a class="sp-story-cta" href="https://thesqueezeproject.com">Visit the fundraiser →</a>
        </div>
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Squeeze Project home",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_pill", "label": "Pill text", "default": "Now taking pre-orders" },
    { "type": "textarea", "id": "hero_heading", "label": "Heading (use <em> for accent)", "default": "Squeeze toys, made for <em>camp</em>." },
    { "type": "textarea", "id": "hero_lede", "label": "Subheading", "default": "Tactile keepsakes for the kids who make summer summer — designed for one camp at a time." },
    { "type": "text", "id": "hero_cta_text", "label": "Primary button text", "default": "Shop the camps" },
    { "type": "url", "id": "hero_cta_link", "label": "Primary button link" },
    { "type": "text", "id": "hero_cta2_text", "label": "Secondary button text", "default": "Read the mission" },
    { "type": "url", "id": "hero_cta2_link", "label": "Secondary button link" },

    { "type": "header", "content": "Camp collections" },
    { "type": "url", "id": "ihc_link", "label": "Camp IHC collection link" },
    { "type": "url", "id": "pontiac_link", "label": "Camp Pontiac collection link" },

    { "type": "header", "content": "Mission band" },
    { "type": "textarea", "id": "mission_body", "label": "Mission paragraph" },
    { "type": "url", "id": "mission_link", "label": "Mission CTA link" }
  ],
  "presets": [
    { "name": "Squeeze Project home" }
  ]
}
{% endschema %}
